direction: right

input: "Input image\n128×128×3" { shape: rectangle }
aug: "Augmentation\nrotation + zoom + translation" { shape: rectangle }
block1: "Conv block 1\nConv32 → Conv32 → MaxPool\noptional BN / Dropout" { shape: rectangle }
block2: "Conv block 2\nConv64 → Conv64 → MaxPool\noptional BN / Dropout" { shape: rectangle }
block3: "Conv block 3\nConv128 → Conv128 → MaxPool\noptional BN / Dropout" { shape: rectangle }
flat: "Flatten" { shape: rectangle }
dense: "Dense head\n256 → 128 → 64\noptional Dropout" { shape: rectangle }
out: "Softmax\n5 classes" { shape: rectangle }

input -> aug -> block1 -> block2 -> block3 -> flat -> dense -> out
